{%- comment -%}
  Trust Badges Snippet
  Displays trust signals below the header or above the footer.
  Usage: {% render 'trust-badges' %}
{%- endcomment -%}

<div class="trust-badges" role="list" aria-label="Trust badges">

  <div class="trust-badge" role="listitem">
    <span class="trust-badge__icon" aria-hidden="true">🚚</span>
    <div class="trust-badge__text">
      <strong>Free Shipping</strong>
      <span>On orders over $50</span>
    </div>
  </div>

  <div class="trust-badge" role="listitem">
    <span class="trust-badge__icon" aria-hidden="true">🔄</span>
    <div class="trust-badge__text">
      <strong>Easy Returns</strong>
      <span>30-day return policy</span>
    </div>
  </div>

  <div class="trust-badge" role="listitem">
    <span class="trust-badge__icon" aria-hidden="true">🔒</span>
    <div class="trust-badge__text">
      <strong>Secure Checkout</strong>
      <span>SSL encrypted payments</span>
    </div>
  </div>

  <div class="trust-badge" role="listitem">
    <span class="trust-badge__icon" aria-hidden="true">⭐</span>
    <div class="trust-badge__text">
      <strong>4.9/5 Rating</strong>
      <span>From 2,000+ reviews</span>
    </div>
  </div>

  <div class="trust-badge" role="listitem">
    <span class="trust-badge__icon" aria-hidden="true">💬</span>
    <div class="trust-badge__text">
      <strong>24/7 Support</strong>
      <span>We're always here to help</span>
    </div>
  </div>

</div>
